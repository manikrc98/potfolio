# Production OAuth App (callback: https://potfolio.me/auth/callback)
GITHUB_CLIENT_ID=your_production_client_id
GITHUB_CLIENT_SECRET=your_production_client_secret

# Local OAuth App (callback: http://localhost:5173/auth/callback)
GITHUB_CLIENT_ID_LOCAL=your_local_client_id
GITHUB_CLIENT_SECRET_LOCAL=your_local_client_secret

SESSION_SECRET=your_session_secret_here
FRONTEND_URL=http://localhost:5173

# Supabase (shared between local and production for session sync)
SUPABASE_URL=your_supabase_url_here
SUPABASE_SERVICE_KEY=your_supabase_service_key_here

CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here
CLOUDFLARE_ZONE_ID=your_cloudflare_zone_id_here
